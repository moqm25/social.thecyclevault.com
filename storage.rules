rules_version = '2';

// The CycleVault Social — Cloud Storage Security Rules
// Source of truth: docs/SECURITY_RULES.md §5 (Phase 0, Accepted).
// Storage is provisioned now; user image uploads (avatars) land in Phase 2.
// Rules are restrictive from day one.

service firebase.storage {
  match /b/{bucket}/o {

    // Public avatars: world-readable, owner-writable, image-only, <= 2 MB.
    match /avatars/{userId}/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // Everything else denied until Phase 2 designs it.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
