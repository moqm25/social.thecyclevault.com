# The CycleVault Social — frontend environment template.
# Copy to `.env.local` (gitignored) for local dev. Real values are generated after
# `firebase login` + web app registration (firebase apps:sdkconfig WEB <appId>).
#
# NOTE: VITE_FIREBASE_* are PUBLIC client config (safe to ship in the bundle).
# Real protection comes from Security Rules + App Check, not from hiding these.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# When "true", the app connects to the local Firebase Emulator Suite instead of
# the live project. Leave true for local development.
VITE_USE_FIREBASE_EMULATORS=true
