# The CycleVault Social — Cloud Functions environment (example)
# Copy to functions/.env (gitignored) and set values. These deploy WITH the functions.

# "Report a problem" email delivery. When "on", each issue report is also written to
# the `mail` collection for the Firebase "Trigger Email from Firestore" extension to
# send to support@thecyclevault.com. Default off = reports live only in the admin
# console. Requires the extension installed with SMTP credentials.
ISSUE_REPORT_EMAILS=off
