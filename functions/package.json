{
	"name": "the-cyclevault-social-functions",
	"description": "The CycleVault Social — Cloud Functions backend (server-authoritative).",
	"private": true,
	"type": "module",
	"main": "lib/index.js",
	"engines": {
		"node": "20"
	},
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"lint": "eslint .",
		"serve": "npm run build && firebase emulators:start --only functions",
		"shell": "npm run build && firebase functions:shell",
		"test": "vitest run",
		"test:watch": "vitest",
		"deploy": "firebase deploy --only functions",
		"logs": "firebase functions:log"
	},
	"dependencies": {
		"firebase-admin": "^13.0.1",
		"firebase-functions": "^6.1.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@types/node": "^20.16.11",
		"eslint": "^9.13.0",
		"typescript": "~5.6.3",
		"typescript-eslint": "^8.11.0",
		"vitest": "^2.1.3"
	}
}
