rules_version = '2';

// The CycleVault Social — Cloud Firestore Security Rules
// Source of truth: docs/SECURITY_RULES.md (Phase 0, Accepted).
// Principle: fail closed; trust the server only. All privileged writes go through
// Cloud Functions (Admin SDK), which bypass these rules. Client-facing rules are
// therefore deliberately strict — mostly read-only or no-access.

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------- helpers -----------------------------------
    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    // Role/status are read from the user's own profile doc.
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function role() { return isSignedIn() ? userDoc().role : 'guest'; }
    function isMod() { return role() in ['moderator', 'admin', 'superadmin']; }
    function isAdmin() { return role() in ['admin', 'superadmin']; }

    // Only these keys may differ between before/after on a client profile edit.
    function changedKeysWithin(allowed) {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(allowed);
    }

    // ------------------------------ users ------------------------------------
    match /users/{userId} {
      allow read: if true; // public pseudonymous profile
      // Clients may only edit displayName + bio on their own doc. avatarUrl is
      // function-only (set by the validated upload flow, Phase 2) to avoid a
      // crafted-URL vector. Type guards prevent confusing non-string writes.
      allow update: if isSignedIn() && userId == uid()
        && changedKeysWithin(['displayName', 'bio', 'updatedAt'])
        && request.resource.data.bio is string
        && request.resource.data.bio.size() <= 300
        && (request.resource.data.displayName == null
          || (request.resource.data.displayName is string
            && request.resource.data.displayName.size() <= 50));
      allow create, delete: if false; // functions only
    }

    // ---------------------------- usernames ----------------------------------
    match /usernames/{name} {
      allow get: if true; // availability check
      allow list, write: if false;
    }

    // --------------------------- communities ---------------------------------
    match /communities/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // ------------------------------ posts ------------------------------------
    match /posts/{postId} {
      allow read: if resource.data.status == 'active' || isMod()
        || (isSignedIn() && resource.data.authorId == uid());
      allow write: if false; // createPost / updatePost / deletePostSoft / lockPost
    }

    // ----------------------------- comments ----------------------------------
    match /comments/{commentId} {
      allow read: if resource.data.status == 'active' || isMod()
        || (isSignedIn() && resource.data.authorId == uid());
      allow write: if false;
    }

    // ------------------------------ votes ------------------------------------
    match /votes/{voteId} {
      allow read: if isSignedIn() && resource.data.uid == uid();
      allow write: if false; // voteOnPost / voteOnComment only
    }

    // ----------------------------- reports -----------------------------------
    match /reports/{reportId} {
      allow read: if isMod()
        || (isSignedIn() && resource.data.reporterId == uid());
      allow write: if false;
    }

    // ------------------------ moderationActions -------------------------------
    match /moderationActions/{id} {
      allow read: if isMod();
      allow write: if false;
    }

    // -------------------------- notifications --------------------------------
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.recipientId == uid();
      allow update: if isSignedIn() && resource.data.recipientId == uid()
        && changedKeysWithin(['read']); // may only flip read
      allow create, delete: if false;
    }

    // ----------------------------- auditLogs ---------------------------------
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ------------------------------- bans ------------------------------------
    match /bans/{id} {
      allow read: if isMod();
      allow write: if false;
    }

    // ----------------------------- settings ----------------------------------
    match /settings/{id} {
      allow read: if true; // feature flags / announcement
      allow write: if false; // admin functions only
    }

    // ------------------------- moderationQueue --------------------------------
    match /moderationQueue/{id} {
      allow read: if isMod(); // full content-review stream (mods/admins)
      allow write: if false; // functions only
    }

    // ------------------------ sponsoredProducts -------------------------------
    // Vetted, clearly-labeled products (docs/MONETIZATION.md). Public can read
    // ACTIVE products to browse the Shop; mods/admins can read all (incl. paused).
    // Writes are function-only (admin upsert/toggle + aggregate click counter).
    match /sponsoredProducts/{id} {
      allow read: if resource.data.active == true || isMod();
      allow write: if false;
    }

    // ------------------------- userModeration ---------------------------------
    // Private moderation counters (strikes, review flag). Kept OFF the public
    // profile doc so strike history isn't world-readable. Mods/admins read; all
    // writes are function-only. The per-user `users/{uid}/strikes` subcollection
    // is denied by the default rule below (function-only via Admin SDK).
    match /userModeration/{userId} {
      allow read: if isMod();
      allow write: if false;
    }

    // ------------------------- issueReports -----------------------------------
    // "Report a problem" submissions (bug/issue reports — NOT user flags). May
    // contain a contact email + a screenshot the reporter chose to attach, so the
    // collection is function-only end-to-end: written via submitIssueReport (open
    // to everyone, rate-limited) and read by admins ONLY through admin callables.
    // No client read access at all — fail closed.
    match /issueReports/{id} {
      allow read, write: if false;
    }

    // ------------------------------- mail -------------------------------------
    // Optional outbound queue for the Firebase "Trigger Email" extension. Written
    // server-side only; never client-readable.
    match /mail/{id} {
      allow read, write: if false;
    }

    // --------------------------- default deny --------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
